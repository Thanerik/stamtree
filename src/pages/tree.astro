---
import FamilyTree from "../components/family/FamilyTree.astro";
import ProtectedLayout from "../layouts/ProtectedLayout.astro";
import { getFamilyTreeData } from "../lib/family";
import { buildTreeLayout } from "../lib/tree-layout";

const tree = await getFamilyTreeData();
const layout = buildTreeLayout(tree);
---

<ProtectedLayout
  title="Stamtræ"
  description="Privat, adgangsbeskyttet stamtræ med tegnnavne og fleksible SVG-relationer."
>
  <main class="tree-page">
    <header class="masthead">
      <div class="intro">
        <h1>Stamtræ</h1>
        <form class="logout" action="/logout" method="get">
          <button type="submit">Log ud</button>
        </form>
        <p class="lede">
          Familiestruktur over børn, børnebørn og videre fra Helle og Einar. Med fødselsdato og tegnnavn hvis muligt. Tegnsprogsbadge på alle personer der kan tegnsprog.
        </p>
      </div>
    </header>

    <FamilyTree tree={tree} layout={layout} />
  </main>

  <style>
    .tree-page {
      padding: 1.5rem;
      display: grid;
      gap: 1.5rem;
      width: max-content;
      min-width: 100%;
    }

    .masthead {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
      align-items: start;
    }

    .intro, article {
      padding: 1.2rem 1.3rem;
      border-radius: 1.5rem;
      background: rgba(255, 255, 255, 0.7);
      border: 1px solid rgba(31, 42, 48, 0.08);
      backdrop-filter: blur(10px);
    }

    .logout {
      float: right;
    }

    .eyebrow,
    .lede,
    .meta p,
    .notes span {
      margin: 0;
      color: #546368;
    }

    .eyebrow {
      margin-bottom: 0.35rem;
      font-size: 0.84rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
    }

    h1 {
      margin: 0;
      font-size: clamp(2.6rem, 7vw, 4.8rem);
      line-height: 0.92;
      letter-spacing: -0.04em;
      font-family: "Instrument Serif", "Georgia", serif;
      font-weight: 400;
    }

    .lede {
      max-width: 52rem;
      margin-top: 0.75rem;
      font-size: 1rem;
      line-height: 1.55;
    }

    .meta {
      display: grid;
      gap: 1rem;
    }

    .meta p {
      line-height: 1.55;
      font-size: 0.95rem;
    }

    .notes {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .notes article {
      display: grid;
      gap: 0.35rem;
    }

    .notes strong {
      font-size: 0.94rem;
    }

    button {
      border: 0;
      border-radius: 999px;
      padding: 0.8rem 1.15rem;
      font: inherit;
      color: white;
      background: #1f2a30;
      cursor: pointer;
    }

    @media (max-width: 980px) {
      .masthead,
      .notes {
        grid-template-columns: 1fr;
      }
    }
  </style>
</ProtectedLayout>
