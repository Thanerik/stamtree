---
import type { TreeConnector } from "../../lib/tree-layout";

interface Props {
  width: number;
  height: number;
  connectors: TreeConnector[];
}

const { width, height, connectors } = Astro.props;
---

<svg class="tree-lines" viewBox={`0 0 ${width} ${height}`} width={width} height={height} aria-hidden="true">
  {
    connectors.map((connector) => (
      <path
        d={connector.points
          .map(([x, y], index) => `${index === 0 ? "M" : "L"} ${x} ${y}`)
          .join(" ")}
      />
    ))
  }
</svg>

<style>
  .tree-lines {
    position: absolute;
    inset: 0;
    overflow: visible;
    pointer-events: none;
    z-index: 2;
  }

  .tree-lines path {
    fill: none;
    stroke: #324147;
    stroke-width: 3.25;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.98;
  }
</style>
